{
  "name": "classwiz-qr",
  "version": "0.0.1",
  "description": "ClassWiz QR Parser",
  "main": "./dist/cwqr.cjs",
  "module": "./dist/cwqr.mjs",
  "browser": "./dist/cwqr.js",
  "exports": {
    ".": {
      "import": "./dist/cwqr.mjs",
      "require": "./dist/cwqr.cjs"
    },
    "./i18n/*.json": "./src/i18n-res/*.json"
  },
  "files": [
    "dist/cwqr.js",
    "dist/cwqr.cjs",
    "dist/cwqr.mjs",
    "dist/*.LICENSE.txt",
    "third-party-licenses.txt",
    "src/i18n-res/*.json"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "test": "node --test --test-reporter=dot \"test/*.js\"",
    "check": "astro check",
    "validate:i18n": "node i18n/test.js",
    "dev": "astro dev",
    "start": "npm run build && wrangler pages dev ./dist --ip=0.0.0.0 --port=8792",
    "build": "npm run validate:i18n && npm run build:site && npm run build:lib && npm run verify:build",
    "build:site": "npm run licenses && astro build",
    "build:lib": "webpack --mode=production --node-env=production",
    "verify:build": "node scripts/verify-build.mjs",
    "build:dev": "npm run licenses && astro build --mode development && webpack --mode=development",
    "build:prod": "npm run build",
    "licenses": "node scripts/generate-third-party-licenses.mjs",
    "watch": "webpack --watch --mode=development",
    "serve": "astro dev",
    "prepack": "npm run validate:i18n && npm run licenses && npm run build:lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CalcWorld/ClassWizQR.git"
  },
  "keywords": [
    "casio",
    "classwiz",
    "casio-calc",
    "qr"
  ],
  "author": "CalcWorld",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/CalcWorld/ClassWizQR/issues"
  },
  "homepage": "https://github.com/CalcWorld/ClassWizQR#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/preact": "^6.0.1",
    "@babel/core": "^7.18.2",
    "@babel/preset-env": "^7.18.2",
    "astro": "^7.1.3",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "jsoneditor": "^10.1.2",
    "mathjax": "2.7.9",
    "preact": "^10.29.7",
    "scratchblocks": "3.7.1",
    "typescript": "^6.0.3",
    "vite-plugin-static-copy": "^3.4.0",
    "webpack": "^5.105.0",
    "webpack-cli": "^5.1.4",
    "wrangler": "4.113.0"
  }
}
